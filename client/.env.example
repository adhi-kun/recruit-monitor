# Backend API URL
VITE_API_URL=http://localhost:4000

# Socket.IO server URL (same as API for development)
VITE_SOCKET_URL=http://localhost:4000

# Agora RTC App ID — from Agora console
VITE_AGORA_APP_ID=your_agora_app_id_here

# Deepgram API Key — for speech-to-text (used client-side via WebSocket)
VITE_DEEPGRAM_API_KEY=your_deepgram_api_key_here
