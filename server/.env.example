# Server Port
PORT=4000

# JWT signing secret — must be at least 32 characters
JWT_SECRET=your_jwt_secret_here_minimum_32_chars

# Allowed frontend origins for CORS
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGIN_PROD=https://yourapp.vercel.app

# Agora RTC App ID — from Agora console
AGORA_APP_ID=your_agora_app_id_here

# Seeded interviewer credentials
INTERVIEWER_EMAIL=interviewer@company.com
INTERVIEWER_PASSWORD=interviewer123

# Seeded supervisor credentials
SUPERVISOR_EMAIL=supervisor@company.com
SUPERVISOR_PASSWORD=supervisor123

# Deepgram API Key — server-side speech-to-text
DEEPGRAM_API_KEY=your_deepgram_api_key_here
